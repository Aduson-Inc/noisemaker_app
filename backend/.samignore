# Exclude unnecessary files from Lambda deployment package

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv

# Testing
tests/
.pytest_cache/
*.pytest_cache

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# AWS SAM build artifacts
.aws-sam/
samconfig.toml

# Development files
lambda_package/
*.zip

# Environment files (secrets should be in Parameter Store)
.env
.env.local
*.pem
*.key

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Requirements (use requirements-lambda.txt instead)
requirements.txt
