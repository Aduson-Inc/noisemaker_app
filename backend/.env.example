# Backend Environment Variables Example
# Copy this file to .env if you want to use local env vars (optional - AWS SSM is preferred)

# AWS Configuration (automatically detected if running on AWS or with configured credentials)
AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Frontend URL for Stripe redirects
# Local development: http://localhost:3000
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:3000

# JWT Secret (optional - loaded from AWS SSM by default at /spotify-promo/jwt-secret-key)
# JWT_SECRET_KEY=your-secret-key-here

# Note: Stripe keys and price IDs are loaded from AWS Parameter Store
# See auth/environment_loader.py for details on SSM parameter paths
